model AppointmentChatMessage {
  id String @id @default(uuid())

  chatId       String @map("chat_id")
  senderUserId String @map("sender_user_id")
  body         String @map("body")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  chat   AppointmentChat @relation(fields: [chatId], references: [id])
  sender User            @relation("AppointmentChatMessages", fields: [senderUserId], references: [id])

  @@index([chatId, createdAt])
  @@index([senderUserId])
  @@map("AppointmentChatMessages")
}
