model MasterServiceReview {
  id           String @id @default(uuid())
  clientUserId String @map("client_user_id")

  rating Int

  text String

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  masterServiceId String @map("master_service_id")

  appointmentId String @unique @map("appointment_id")

  masterService MasterService @relation(fields: [masterServiceId], references: [id], onDelete: Cascade)
  clientUser    User          @relation(fields: [clientUserId], references: [id], onDelete: Cascade)
  appointment   Appointment   @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  reactions     MasterServiceReviewReaction[]

  @@index([masterServiceId, createdAt])
  @@index([clientUserId])
  @@index([deletedAt])
  @@map("MasterServiceReviews")
}
