model MasterServiceImage {
  id String @id @default(uuid())

  masterServiceId String @map("master_service_id")
  fileId          String @map("file_id")

  masterService MasterService @relation(fields: [masterServiceId], references: [id], onDelete: Cascade)
  file          File          @relation(fields: [fileId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([masterServiceId, fileId])
  @@index([masterServiceId])
  @@index([fileId])
  @@map("MasterServiceImages")
}
