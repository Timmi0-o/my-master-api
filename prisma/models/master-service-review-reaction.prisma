model MasterServiceReviewReaction {
  id String @id @default(uuid())

  userId                 String                         @map("user_id")
  masterServiceReviewId  String                         @map("master_service_review_id")
  type                   MasterServiceReviewReactionType @map("type")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  user                User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  masterServiceReview MasterServiceReview @relation(fields: [masterServiceReviewId], references: [id], onDelete: Cascade)

  @@unique([userId, masterServiceReviewId])
  @@index([masterServiceReviewId])
  @@index([type])
  @@index([deletedAt])
  @@map("MasterServiceReviewReactions")
}

enum MasterServiceReviewReactionType {
  LIKE
  DISLIKE
}
