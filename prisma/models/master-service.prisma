model MasterService {
  id              String                @id @default(uuid())
  name            String                @map("name")
  description     String                @map("description")
  price           Float                 @map("price")
  durationMinutes Int                   @default(60) @map("duration_minutes")
  category        MasterServiceCategory @default(SERVICES) @map("category")

  masterProfileId String @map("master_profile_id")

  masterProfile MasterProfile           @relation(fields: [masterProfileId], references: [id])
  appointments  Appointment[]
  images        MasterServiceImage[]
  reviews       MasterServiceReview[]
  favorites     FavoriteMasterService[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  @@index([category])
  @@map("MasterServices")
}

enum MasterServiceCategory {
  BEAUTY
  REPAIR
  AUTO
  HOME
  PARTS
  SERVICES
  DIGITAL
  PHOTO
  SPORT
  DESIGN
  WELLNESS
}
