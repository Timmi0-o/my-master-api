model User {
  id String @id @default(uuid())

  email    String  @map("email")
  phone    String? @map("phone")
  username String  @map("username")

  roleId String @map("role_id")
  status Status @default(PENDING) @map("status")

  passwordHash String @map("password_hash")

  name       String  @map("name")
  surname    String  @map("surname")
  patronymic String? @map("patronymic")

  language Language @default(RU) @map("language")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  role Role @relation(fields: [roleId], references: [id], onDelete: Restrict)

  masterProfile MasterProfile?
  userProfile   UserProfile?

  sessions                Session[]
  refreshTokens           RefreshToken[]
  clientAppointments      Appointment[]            @relation("ClientAppointments")
  appointmentChatMessages AppointmentChatMessage[] @relation("AppointmentChatMessages")
  masterServiceReviews    MasterServiceReview[]

  @@unique([email])
  @@unique([phone])
  @@unique([username])
  @@index([email, phone, username])
  @@index([roleId])
  @@map("Users")
}

enum Status {
  ACTIVE
  INACTIVE
  PENDING
  BLOCKED
}

enum Language {
  RU
}
